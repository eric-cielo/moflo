{
  "name": "moflo",
  "version": "4.8.50",
  "description": "MoFlo — AI agent orchestration for Claude Code. Forked from ruflo/claude-flow with patches applied to source, plus feature-level orchestration.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "flo": "bin/cli.js",
    "flo-setup": "bin/setup-project.mjs",
    "flo-codemap": "bin/generate-code-map.mjs",
    "flo-search": "bin/semantic-search.mjs",
    "flo-embeddings": "bin/build-embeddings.mjs",
    "flo-index": "bin/index-guidance.mjs",
    "flo-testmap": "bin/index-tests.mjs",
    "moflo": "bin/cli.js",
    "claude-flow": "bin/cli.js"
  },
  "homepage": "https://github.com/eric-cielo/moflo#readme",
  "bugs": {
    "url": "https://github.com/eric-cielo/moflo/issues"
  },
  "files": [
    "bin/**",
    "src/@claude-flow/cli/bin/**",
    "src/@claude-flow/cli/dist/**/*.js",
    "!src/@claude-flow/cli/dist/**/*.map",
    "src/@claude-flow/cli/package.json",
    "src/@claude-flow/shared/dist/**/*.js",
    "!src/@claude-flow/shared/dist/**/*.map",
    "src/@claude-flow/shared/package.json",
    "src/@claude-flow/guidance/dist/**/*.js",
    "!src/@claude-flow/guidance/dist/**/*.map",
    "src/@claude-flow/guidance/package.json",
    "src/@claude-flow/memory/dist/**/*.js",
    "!src/@claude-flow/memory/dist/**/*.map",
    "src/@claude-flow/memory/package.json",
    "src/@claude-flow/neural/dist/**/*.js",
    "!src/@claude-flow/neural/dist/**/*.map",
    "src/@claude-flow/neural/package.json",
    ".claude/commands/**/*.md",
    ".claude/agents/**/*.md",
    ".claude/helpers/**",
    ".claude/guidance/shipped/**",
    "!.claude/**/*.db",
    "!.claude/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc -b",
    "build:ts": "cd src/@claude-flow/cli && npm run build",
    "build:neural": "cd src/@claude-flow/neural && npx tsc -p tsconfig.json",
    "build:guidance": "cd src/@claude-flow/guidance && npx tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:security": "vitest run src/__tests__/security/",
    "lint": "cd src/@claude-flow/cli && npm run lint || true",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "moflo:security": "npm run security:audit && npm run security:test",
    "version": "node scripts/sync-version.mjs && git add src/@claude-flow/cli/package.json src/@claude-flow/cli/src/version.ts"
  },
  "dependencies": {
    "@ruvector/learning-wasm": "^0.1.29",
    "js-yaml": "^4.1.1",
    "semver": "^7.7.4",
    "sql.js": "^1.14.1",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "@claude-flow/plugin-gastown-bridge": "^0.1.3",
    "@ruvector/attention": "^0.1.3",
    "@ruvector/core": "^0.1.30",
    "@ruvector/router": "^0.1.27",
    "@ruvector/sona": "^0.1.5",
    "@xenova/transformers": "^2.17.0",
    "agentdb": "^3.0.0-alpha.9",
    "agentic-flow": "^2.0.7"
  },
  "overrides": {
    "hono": ">=4.11.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "eslint": "^8.0.0",
    "moflo": "^4.8.47",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eric-cielo/moflo.git"
  },
  "keywords": [
    "moflo",
    "claude",
    "claude-code",
    "anthropic",
    "ai-agents",
    "agent-orchestration",
    "mcp",
    "model-context-protocol",
    "cli",
    "developer-tools",
    "workflow",
    "orchestration"
  ],
  "author": {
    "name": "Eric Cielo",
    "url": "https://github.com/eric-cielo"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
