{
  "name": "moflo",
  "version": "4.8.73",
  "description": "MoFlo — AI agent orchestration for Claude Code. Forked from ruflo/claude-flow with patches applied to source, plus feature-level orchestration.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "flo": "bin/cli.js",
    "flo-setup": "bin/setup-project.mjs",
    "flo-codemap": "bin/generate-code-map.mjs",
    "flo-search": "bin/semantic-search.mjs",
    "flo-embeddings": "bin/build-embeddings.mjs",
    "flo-index": "bin/index-guidance.mjs",
    "flo-testmap": "bin/index-tests.mjs",
    "moflo": "bin/cli.js",
    "claude-flow": "bin/cli.js"
  },
  "homepage": "https://github.com/eric-cielo/moflo#readme",
  "bugs": {
    "url": "https://github.com/eric-cielo/moflo/issues"
  },
  "files": [
    "bin/**",
    "src/modules/cli/bin/**",
    "src/modules/cli/dist/**/*.js",
    "src/modules/cli/dist/**/*.yaml",
    "!src/modules/cli/dist/**/*.map",
    "src/modules/cli/package.json",
    "src/modules/shared/dist/**/*.js",
    "!src/modules/shared/dist/**/*.map",
    "src/modules/shared/package.json",
    "src/modules/guidance/dist/**/*.js",
    "!src/modules/guidance/dist/**/*.map",
    "src/modules/guidance/package.json",
    "src/modules/memory/dist/**/*.js",
    "!src/modules/memory/dist/**/*.map",
    "src/modules/memory/package.json",
    "src/modules/neural/dist/**/*.js",
    "!src/modules/neural/dist/**/*.map",
    "src/modules/neural/package.json",
    "src/modules/spells/dist/**/*.js",
    "!src/modules/spells/dist/**/*.map",
    "src/modules/spells/package.json",
    "src/modules/hooks/dist/**/*.js",
    "!src/modules/hooks/dist/**/*.map",
    "src/modules/hooks/package.json",
    "src/modules/swarm/dist/**/*.js",
    "!src/modules/swarm/dist/**/*.map",
    "src/modules/swarm/package.json",
    "src/modules/security/dist/**/*.js",
    "!src/modules/security/dist/**/*.map",
    "src/modules/security/package.json",
    "src/modules/embeddings/dist/**/*.js",
    "!src/modules/embeddings/dist/**/*.map",
    "src/modules/embeddings/package.json",
    "src/modules/plugins/dist/**/*.js",
    "!src/modules/plugins/dist/**/*.map",
    "src/modules/plugins/package.json",
    "!src/modules/*/README.md",
    "!src/README.md",
    "!**/*.test.js",
    "!**/*.spec.js",
    "!**/__tests__/**",
    ".claude/commands/**/*.md",
    ".claude/agents/**/*.md",
    ".claude/helpers/**",
    ".claude/guidance/shipped/**",
    ".claude/skills/**/*.md",
    "!.claude/**/*.db",
    "!.claude/**/*.map",
    "spells/shipped/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc -b && node -e \"const{cpSync}=require('fs');cpSync('src/modules/cli/src/epic/spells','src/modules/cli/dist/src/epic/spells',{recursive:true})\"",
    "build:ts": "cd src/modules/cli && npm run build",
    "build:neural": "cd src/modules/neural && npx tsc -p tsconfig.json",
    "build:guidance": "cd src/modules/guidance && npx tsc -p tsconfig.json",
    "prepublishOnly": "node scripts/check-version-sync.mjs && npm run build",
    "test": "node scripts/test-runner.mjs",
    "test:ui": "vitest --ui",
    "test:security": "vitest run src/__tests__/security/",
    "lint": "cd src/modules/cli && npm run lint || true",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "moflo:security": "npm run security:audit && npm run security:test",
    "version": "node scripts/sync-version.mjs && git add src/modules/cli/package.json src/modules/cli/src/version.ts",
    "flo": "flo"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.3.5",
    "semver": "^7.7.4",
    "sql.js": "^1.14.1",
    "valibot": "^1.3.1"
  },
  "optionalDependencies": {
    "@claude-flow/plugin-gastown-bridge": "^0.1.3",
    "@xenova/transformers": "^2.17.0",
    "agentdb": "^3.0.0-alpha.9",
    "agentic-flow": "^2.0.7"
  },
  "overrides": {
    "hono": ">=4.11.4",
    "picomatch": ">=2.3.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "eslint": "^8.0.0",
    "moflo": "^4.8.72",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eric-cielo/moflo.git"
  },
  "keywords": [
    "moflo",
    "claude",
    "claude-code",
    "anthropic",
    "ai-agents",
    "agent-orchestration",
    "mcp",
    "model-context-protocol",
    "cli",
    "developer-tools",
    "workflow",
    "orchestration"
  ],
  "author": {
    "name": "Eric Cielo",
    "url": "https://github.com/eric-cielo"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
