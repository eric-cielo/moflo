# Source maps - not needed for production (saves 464 files, ~33% size reduction)
**/*.map
**/*.js.map
**/*.d.ts.map

# Development files
**/__tests__/**
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
**/vitest.config.*
**/.eslintrc.*
**/tsconfig.json
**/jest.config.*

# Build artifacts
**/node_modules/**
**/.turbo/**
**/.cache/**

# Database files (user-specific)
**/*.db
**/*.db-shm
**/*.db-wal
**/hnsw.index
**/hnsw.metadata.json

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# V2 legacy (not needed in npm package)
v2/

# Type declarations (consumers use moflo as CLI, not as a TS library)
**/*.d.ts

# Development docs
docs/
*.md
!README.md
!LICENSE
!.claude/guidance/shipped/*.md
!.claude/commands/**/*.md
!.claude/agents/**/*.md

# Sub-package READMEs — npm force-includes README.md next to any
# package.json in the files array, so this is a no-op for now.
# Kept as documentation of intent.
src/modules/*/README.md
src/README.md

# Git
.git/
.gitignore
.github/

# Swarm state (user-specific)
.swarm/

# Temporary
tmp/
temp/
*.tmp
*.log
